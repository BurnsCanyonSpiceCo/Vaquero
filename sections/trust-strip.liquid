<section class="trust-strip" aria-label="Shopping benefits">
  {% for block in section.blocks %}
    <div {{ block.shopify_attributes }}>
      <svg class="trust-icon" aria-hidden="true" viewBox="0 0 24 24">
        {% case block.settings.icon %}
          {% when 'leaf' %}
            <path d="M12 3v18M5 8c4.5 0 7 2.5 7 7-4.5 0-7-2.5-7-7Z"/>
            <path d="M19 8c-4.5 0-7 2.5-7 7 4.5 0 7-2.5 7-7Z"/>
          {% when 'check' %}
            <path d="m7 11 3 3 7-7"/>
            <path d="M21 12a9 9 0 1 1-5.3-8.2"/>
          {% when 'cloche' %}
            <path d="M4 14h16"/>
            <path d="M6 14a6 6 0 0 1 12 0"/>
            <path d="M8 18h8"/>
            <path d="M12 4v3"/>
          {% else %}
            <path d="M6 10V8a6 6 0 0 1 12 0v2"/>
            <rect width="16" height="11" x="4" y="10" rx="2"/>
            <path d="M12 15v2"/>
        {% endcase %}
      </svg>
      <span>
        <strong>{{ block.settings.heading }}</strong>
        <small>{{ block.settings.text }}</small>
      </span>
    </div>
  {% endfor %}
</section>

{% schema %}
{
  "name": "Trust strip",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "leaf",
          "options": [
            { "value": "leaf", "label": "Leaf" },
            { "value": "check", "label": "Check" },
            { "value": "cloche", "label": "Serving dome" },
            { "value": "lock", "label": "Lock" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Handcrafted in small batches"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Made in Pioneertown, CA"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust strip",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "leaf",
            "heading": "Handcrafted in small batches",
            "text": "Made in Pioneertown, CA"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "check",
            "heading": "Clean ingredients",
            "text": "No fillers, no shortcuts"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "cloche",
            "heading": "Everyday versatile",
            "text": "Breakfast to barbecue"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "lock",
            "heading": "Secure checkout",
            "text": "Cards, wallets, and Shop Pay ready"
          }
        }
      ]
    }
  ]
}
{% endschema %}
