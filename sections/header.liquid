<aside class="announcement" aria-label="Store promotion">
  <p>
    <strong>{{ section.settings.announcement_strong }}</strong>
    {{ section.settings.announcement_text }}
    <span>{{ section.settings.announcement_code }}</span>
  </p>
  <button class="icon-button announcement__close" type="button" aria-label="Dismiss promotion">x</button>
</aside>

<header class="site-header">
  <nav class="nav" aria-label="Main navigation">
    <a class="brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }} home">
      <span>{{ section.settings.brand_top }}</span>
      <small>{{ section.settings.brand_bottom }}</small>
    </a>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-menu">
      <span></span>
      <span></span>
      <span></span>
      <span class="sr-only">Open menu</span>
    </button>

    <div class="nav-menu" id="site-menu">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% else %}
        <a href="{{ routes.root_url }}#shop">Shop</a>
        <a href="{{ routes.root_url }}#why">What It Is</a>
        <a href="{{ routes.root_url }}#story">Our Story</a>
        <a href="{{ routes.root_url }}#reviews">Reviews</a>
        <a href="{{ routes.root_url }}#wholesale">Wholesale</a>
      {% endfor %}
    </div>

    <div class="nav-actions">
      <a class="login-link" href="{{ routes.account_url }}">Login</a>
      <a class="cart-button" href="{{ routes.cart_url }}" aria-label="Open cart">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M6.2 6h15l-1.9 8.4a2 2 0 0 1-2 1.6H9.1a2 2 0 0 1-2-1.7L5.8 4.8A2 2 0 0 0 3.8 3H2"/>
          <circle cx="9" cy="20" r="1.5"/>
          <circle cx="18" cy="20" r="1.5"/>
        </svg>
        <span class="cart-count">{{ cart.item_count }}</span>
      </a>
    </div>
  </nav>
</header>

<aside class="cart-drawer" aria-hidden="true" aria-labelledby="cart-drawer-title">
  <div class="cart-drawer__panel" role="dialog" aria-modal="true">
    <div class="cart-drawer__header">
      <h2 id="cart-drawer-title">Your cart</h2>
      <button class="icon-button cart-close" type="button" aria-label="Close cart">x</button>
    </div>
    <div class="cart-items" aria-live="polite">
      {% if cart.item_count == 0 %}
        <p class="empty-cart">Your cart is ready for bold flavor.</p>
      {% else %}
        {% for item in cart.items %}
          <article class="cart-line">
            {% if item.image %}
              {{ item.image | image_url: width: 120 | image_tag: alt: item.product.title }}
            {% endif %}
            <div>
              <strong>{{ item.product.title }}</strong>
              <span>Qty {{ item.quantity }}</span>
            </div>
            <b>{{ item.final_line_price | money }}</b>
          </article>
        {% endfor %}
      {% endif %}
    </div>
    <div class="cart-drawer__footer">
      <div class="cart-total">
        <span>Estimated subtotal</span>
        <strong>{{ cart.total_price | money }}</strong>
      </div>
      <a class="button button--primary button--full" href="{{ routes.checkout_url }}">Checkout</a>
      <p class="microcopy">Free shipping at $60. Secure checkout. Small batches ship while fresh.</p>
    </div>
  </div>
</aside>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_strong",
      "label": "Announcement strong text",
      "default": "Free shipping"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "on orders $60+ with code"
    },
    {
      "type": "text",
      "id": "announcement_code",
      "label": "Announcement code",
      "default": "FREESHIPPING"
    },
    {
      "type": "text",
      "id": "brand_top",
      "label": "Brand top line",
      "default": "Burns Canyon"
    },
    {
      "type": "text",
      "id": "brand_bottom",
      "label": "Brand bottom line",
      "default": "Spice Co."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    }
  ]
}
{% endschema %}
