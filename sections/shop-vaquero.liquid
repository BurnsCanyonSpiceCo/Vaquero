<section class="shop-section" id="shop" aria-labelledby="shop-title">
  <div class="section-heading">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 id="shop-title">{{ section.settings.heading }}</h2>
    <p>{{ section.settings.body }}</p>
  </div>

  <div class="filters" role="group" aria-label="Filter products">
    <button class="filter is-active" type="button" data-filter="all">All</button>
    <button class="filter" type="button" data-filter="sauce">Sauce</button>
    <button class="filter" type="button" data-filter="seasoning">Seasoning</button>
    <button class="filter" type="button" data-filter="bundle">Bundles</button>
    <button class="filter" type="button" data-filter="subscribe">Subscribe</button>
  </div>

  <div class="product-grid">
    {% for block in section.blocks %}
      {% assign card_product = block.settings.product %}
      {% assign product_url = block.settings.fallback_url %}
      {% if card_product != blank %}
        {% assign product_url = card_product.url %}
      {% endif %}
      {% case block.settings.card_image %}
        {% when 'spoon' %}
          {% assign image_asset = 'morita-spoon.png' %}
        {% when 'bundle' %}
          {% assign image_asset = 'bundle-card.png' %}
        {% when 'seasoning-open' %}
          {% assign image_asset = 'seasoning-open.png' %}
        {% else %}
          {% assign image_asset = 'subscription-card.png' %}
      {% endcase %}
      <article class="product-card" data-category="{{ block.settings.category }}" {{ block.shopify_attributes }}>
        <a class="product-card__image" href="{{ product_url }}" aria-label="View {{ block.settings.title }}">
          <img src="{{ image_asset | asset_url }}" width="900" height="900" alt="{{ block.settings.image_alt | escape }}">
          {% if block.settings.badge != blank %}
            <span class="badge{% if block.settings.badge_tone == 'green' %} badge--green{% endif %}">{{ block.settings.badge }}</span>
          {% endif %}
        </a>
        <div class="product-card__body">
          <div class="rating" aria-label="Rated 5 out of 5 stars">
            <span aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <a href="#reviews">{{ block.settings.rating_text }}</a>
          </div>
          <h3><a href="{{ product_url }}">{{ block.settings.title }}</a></h3>
          <p>{{ block.settings.description }}</p>
          <div class="product-card__footer">
            <span class="price">
              {% if card_product != blank %}
                {% if card_product.price_varies %}from {% endif %}{{ card_product.price_min | money }}
              {% else %}
                {{ block.settings.fallback_price }}
              {% endif %}
            </span>
            {% if card_product != blank and card_product.available %}
              {% form 'product', card_product, class: 'quick-add-form', data-add-to-cart-form: '' %}
                <input type="hidden" name="id" value="{{ card_product.selected_or_first_available_variant.id }}">
                <button class="button button--compact quick-add" type="submit">Add</button>
              {% endform %}
            {% else %}
              <a class="button button--compact" href="{{ product_url }}">View</a>
            {% endif %}
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Shop Vaquero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop Vaquero"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your flavor plan."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Start with the spoonable Chile Morita, add the dry seasoning, bundle both everyday essentials, or subscribe so Vaquero is always within reach."
    }
  ],
  "blocks": [
    {
      "type": "product_card",
