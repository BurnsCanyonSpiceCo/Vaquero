      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Shopify product"
        },
        {
          "type": "select",
          "id": "category",
          "label": "Filter category",
          "default": "sauce",
          "options": [
            { "value": "sauce", "label": "Sauce" },
            { "value": "seasoning", "label": "Seasoning" },
            { "value": "bundle", "label": "Bundle" },
            { "value": "subscribe", "label": "Subscribe" }
          ]
        },
        {
          "type": "select",
          "id": "card_image",
          "label": "Homepage card image",
          "default": "spoon",
          "options": [
            { "value": "spoon", "label": "Chile Morita spoon" },
            { "value": "bundle", "label": "Bundle group" },
            { "value": "seasoning-open", "label": "Open seasoning jar" },
            { "value": "subscription", "label": "Subscription multi-jar" }
          ]
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "Vaquero product"
        },
        {
          "type": "text",
          "id": "fallback_url",
          "label": "Fallback product URL",
          "default": "/products/vaquero-chile-morita-sauce"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge"
        },
        {
          "type": "select",
          "id": "badge_tone",
          "label": "Badge tone",
          "default": "orange",
          "options": [
            { "value": "orange", "label": "Orange" },
            { "value": "green", "label": "Green" }
          ]
        },
        {
          "type": "text",
          "id": "rating_text",
          "label": "Rating text",
          "default": "21 reviews"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Vaquero Chile Morita Sauce"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Small-batch smoky chipotle chile oil made with morita, garlic, and avocado oil."
        },
        {
          "type": "text",
          "id": "fallback_price",
          "label": "Fallback price",
          "default": "from $7.50"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop Vaquero",
      "blocks": [
        {
